<!DOCTYPE html>
<html lang="en">
<head>
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Events</title>
        <link rel="icon" href="/static/image/title-logo.png" type="image/icon type">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
        <meta http-equiv="refresh" content="delay_time; URL=new_website_url" />
        <link rel="stylesheet" href="/static/css/style.css">
        <link rel="stylesheet" href="/static/css/show.css">
        <link rel="stylesheet" href="/static/css/navbar.css">
        <link rel="stylesheet" href="/static/css/header.css">
        <link rel="stylesheet" href="/static/css/index/footer.css">
</head>
<body>
  {{>header}}
  <hr>
  <ul class="topnav">
    {{>navbar}}
  </ul>
  <div class="grid-container">
      <img class="img1" src="/static/image/geo1.webp" />
      
      <div class="container">
        {{#each data}}

        <div class="mark">
        <span class="panel" id="event"><h3>{{event}}</h3>
        </span>
        
        <br>
        
        <span class="panel active fa fa-calendar" id="date">
            {{date}}
        </span>
        <br>
        <span class="panel" id="committee">{{committee}} Committee</span>
      
        <br>
        
        <span class="panel" id="comp">Status : {{comp}}</span>
        <br>
        
        <span class="panel" id="link"> For More Details : 
          <a class="my-report" href='/show/report/{{_id}}'>
          Click</a></span>
            
        </div>
        {{/each}}
      </div>
      
</div>

{{>footer}}

</body>
<script>
  const panels = document.querySelectorAll(".panel");
  panels.forEach((panel)=>{
    panel.addEventListner("click",()=>{
      removeActiveClasses();
      panel.classList.add("active");
    })
  });
  const removeActiveClasses=()=>{
    panels.forEach((panel)=>{
      panels.classList.remove("active");
    })
  };
 
</script>

</html>